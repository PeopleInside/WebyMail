Options -Indexes
RewriteEngine On

# Route all requests through index.php except assets and existing files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # Allow HTTPS images to render user-provided signatures and inline editor content.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data: blob:; font-src 'self'; connect-src 'self'; worker-src 'self' blob:; frame-src 'self';"
</IfModule>

# Deny access to sensitive directories
RedirectMatch 404 ^/(?:config|data|src|templates)(?:/.*)?$
# NOTE: setup.php is intentionally NOT blocked here.
# The PHP code in setup.php handles its own access control:
# it redirects to index.php if setup is already complete and ?force=1 is absent.
# Blocking it here would prevent the update wizard (setup.php?force=1) from running.
RedirectMatch 404 ^/(?:composer\.(?:json|lock)|README\.md|LICENSE|SECURITY\.md|\.env)$
RedirectMatch 404 ^/\.git(?:/.*)?$
RedirectMatch 404 ^/.*\.bak$
